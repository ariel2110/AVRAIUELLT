# =============================================================================
# .env.example — Vault Server Environment Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Replace EVERY value marked CHANGE_THIS with strong random secrets.
#   3. Set VAULT_INTERNAL_IP to your Hostinger private VPC IP (e.g. 10.0.0.4).
#   4. NEVER commit .env to version control.
#
# Generate strong passwords:
#   openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------
# PostgreSQL credentials
# -----------------------------------------------------------
POSTGRES_DB=vault_db
POSTGRES_USER=vault_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_RANDOM_PASSWORD_32_CHARS

# -----------------------------------------------------------
# SQLAlchemy async DSN — uses asyncpg driver.
# Host 'db' resolves inside Docker to the postgres container.
# -----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vault_user:CHANGE_THIS_STRONG_RANDOM_PASSWORD_32_CHARS@db:5432/vault_db

# -----------------------------------------------------------
# Internal authentication keys
# Comma-separated list of valid keys for X-Vault-Internal-Key header.
# Multiple keys allow zero-downtime rotation:
#   - Add a new key, redeploy Admin, then remove the old key.
# Generate each key with:  openssl rand -hex 32
# -----------------------------------------------------------
VAULT_INTERNAL_KEYS=CHANGE_THIS_KEY_ONE,CHANGE_THIS_KEY_TWO

# -----------------------------------------------------------
# Admin authentication keys (X-Vault-Admin-Key header)
# Used exclusively by privileged endpoints (e.g. POST /admin/mint).
# Must be different from VAULT_INTERNAL_KEYS — never share key sets.
# Generate each key with:  openssl rand -hex 32
# -----------------------------------------------------------
VAULT_ADMIN_KEYS=CHANGE_THIS_ADMIN_KEY_ONE

# -----------------------------------------------------------
# Treasury wallet UUID
# The ONLY wallet that may receive minted Taz via POST /admin/mint.
# Create the wallet first via POST /wallets/create, then paste its
# user_id here.  Use a stable UUID you control.
# Generate with:  python3 -c "import uuid; print(uuid.uuid4())"
# -----------------------------------------------------------
TREASURY_WALLET_ID=CHANGE_THIS_TO_TREASURY_UUID

# -----------------------------------------------------------
# Hostinger private VPC / private network IP of THIS server.
# The FastAPI port will bind ONLY to this IP.
# Find it in: Hostinger panel → VPS → Private Networks
# Example: 10.0.0.4
# -----------------------------------------------------------
VAULT_INTERNAL_IP=10.0.0.4
